TELEAPP_TOKEN=<your telegram bot token>
TELEAPP_ALLOWED_USER_ID=<your telegram user id>
TELEAPP_CHAT_ID=<optional default chat id>
TELEAPP_APP=examples/echo_app.py
TELEAPP_PYTHON=python
TELEAPP_HOT_RELOAD=1
TELEAPP_AUTO_RESTART_ON_CRASH=1
TELEAPP_RELOAD_QUIET_SECONDS=2
TELEAPP_RELOAD_POLL_SECONDS=1
TELEAPP_RESTART_BACKOFF_SECONDS=1
